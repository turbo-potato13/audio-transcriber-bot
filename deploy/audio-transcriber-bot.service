[Unit]
Description=Audio Transcriber Telegram Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/audio-transcriber-bot
EnvironmentFile=/home/ubuntu/audio-transcriber-bot/.env
ExecStart=/home/ubuntu/audio-transcriber-bot/.venv/bin/python -m bot.main
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
