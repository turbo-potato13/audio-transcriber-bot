BOT_TOKEN=
SPEECH_TO_TEXT_API_KEY=

# Comma-separated Telegram chat IDs. Send /chatid or /chatId to the bot to get this value.
# Example for private chat: 123456789
# Example for group/supergroup: -1001234567890
ALLOWED_CHAT_IDS=

DOWNLOAD_DIR=tmp/downloads
MAX_FILE_MB=20

# Optional OpenAI-compatible speech-to-text settings.
SPEECH_TO_TEXT_API_URL=https://api.openai.com/v1/audio/transcriptions
SPEECH_TO_TEXT_MODEL=whisper-1
SPEECH_TO_TEXT_LANGUAGE=
SPEECH_TO_TEXT_TIMEOUT_SECONDS=120
